      './database/models' \
      './database/mongodb' \
      './database/redis' \
      './database/repositories' \
      './database/schema' \
      './database/services' \
      './monitoring/grafana' \
      './resource_monitor/config' \
      './server_manager/config' \
      './service_configs/admin' \
      './service_configs/auth' \
      './service_configs/base' \
      './service_configs/blockchain' \
      './service_configs/database' \
      './service_configs/distroless' \
      './service_configs/electron_gui' \
      './service_configs/gui' \
      './service_configs/logging' \
      './service_configs/multi-stage' \
      './service_configs/node' \
      './service_configs/payment_services' \
      './service_configs/payment_systems' \
      './service_configs/rdp' \
      './service_configs/security' \
      './service_configs/server' \
      './service_configs/service_mesh' \
      './service_configs/sessions' \
      './service_configs/tor' \
      './service_configs/x_lucid_cluster_calibration' \
      './session_controller/config' \
      './session_controller/integration' \
      './database/services/backup' \
      './database/services/migration' \
