# syntax=docker/dockerfile:1.5
# LUCID SERVER OPERATIONS — Distroless Python orchestrator
# Aligned with 03_api_gateway/Dockerfile (wheel build, cache mounts, verification)
# Image: pickme/lucid-server-operations:latest-arm64
# Build context: repository root (.)
#
# Role: Single distroless image with all Lucid server-side handler modules on PYTHONPATH
#       (lifecycle API via server_manager, plus session control, protocol, resource monitor,
#       security, shared config, and monitoring artifacts). Process entry remains
#       server_manager/entrypoint.py — that service coordinates subsystem handlers.
#
# Runtime layout: /app handlers + /usr/local site-packages (matches server_manager/entrypoint.py)
#
# Registry + service fragments (host-config.yml, infrastructure/containers/services/*.yml):
#   • host-config.yml services.lucid_server_manager — service_name lucid-server-manager, port 8081,
#     host_ip 172.20.10.3, http_path http://lucid-server-manager:8081/app
#   • /app/service_configs/ — container-runtime-layout, rdp-services, session-management, etc.
#     (see infrastructure/containers/services/rdp-services.yml for /app/service_configs paths)

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=1.0.0
ARG TARGETPLATFORM=linux/arm64
ARG BUILDPLATFORM=linux/amd64
ARG PYTHON_VERSION=3.11

############################
# Stage 1 – Builder
############################
FROM --platform=$TARGETPLATFORM python:3.11-slim-bookworm AS builder

ARG BUILDPLATFORM
ARG TARGETPLATFORM
ARG PYTHON_VERSION

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_PREFER_BINARY=1 \
    DEBIAN_FRONTEND=noninteractive

WORKDIR /build
# LUCID_IMAGE_CONFIG: .env.secrets + .env.master + host-config + container services (builder)
COPY configs/environment/.env.secrets /build/configs/.env.secrets
COPY master-env-config.txt /build/configs/.env.master
COPY infrastructure/containers/services/x_lucid_cluster_calibration/core-cluster-host-alignment.yml ./service_configs/x_lucid_cluster_calibration/core-cluster-host-alignment.yml
COPY infrastructure/containers/host-config.yml /build/configs/host-config.yml
COPY infrastructure/containers/services/ /build/service_configs/


RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    rm -rf /var/lib/apt/lists/* && \
    apt-get update --allow-releaseinfo-change && \
    apt-get install -y --no-install-recommends \
        build-essential \
        bash \
        gcc \
        g++ \
        libffi-dev \
        libssl-dev \
        pkg-config \
        curl \
        ca-certificates \
        tini \
        python3-wheel \
        python3-dev \
        python3-pip \
        python3-setuptools \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

RUN printf "LUCID_SERVER_OPERATIONS_RUNTIME" > /var/run/.keep && \
    printf "LUCID_SERVER_OPERATIONS_LIB" > /var/lib/.keep && \
    chown -R 65532:65532 /var/run /var/lib && \
    chmod 644 /var/run/.keep /var/lib/.keep

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --upgrade pip setuptools wheel

COPY RDP/requirements.server-manager.txt ./requirements.server-manager.txt
COPY RDP/security/requirements.security.txt ./requirements.security.txt

RUN --mount=type=cache,target=/root/.cache/pip \
    mkdir -p /build/wheels && \
    printf "LUCID_SERVER_OPERATIONS_WHEELS_$(date +%s)" > /build/wheels/.keep && \
    pip wheel --no-cache-dir --wheel-dir /build/wheels -r ./requirements.server-manager.txt && \
    pip wheel --no-cache-dir --wheel-dir /build/wheels -r ./requirements.security.txt
# LUCID_X_FILES_SKELETON_BEGIN
# Dirs: (listing ∩ COPY-approved) ∪ builder-stage COPY roots; after pip cache RUN or before first /build COPY
RUN set -eux; \
    mkdir -p '.' './client' './common' './config' './configs' './database' './monitoring' './protocol' './resource_monitor' './security' './server' './server_manager' './service_configs' './session_controller' './common/governance' './common/security' './common/server-tools' './common/tor' './configs/docker' './database/api' './database/config' './database/elasticsearch' './database/models' './database/mongodb' './database/redis' './database/repositories' './database/schema' './database/services' './monitoring/grafana' './resource_monitor/config' './server_manager/config' './service_configs/admin' './service_configs/auth' './service_configs/base' './service_configs/blockchain' './service_configs/database' './service_configs/distroless' './service_configs/electron_gui' './service_configs/gui' './service_configs/logging' './service_configs/multi-stage' './service_configs/node' './service_configs/payment_services' './service_configs/payment_systems' './service_configs/rdp' './service_configs/security' './service_configs/server' './service_configs/service_mesh' './service_configs/sessions' './service_configs/tor' './service_configs/x_lucid_cluster_calibration' './session_controller/config' './session_controller/integration' './database/services/backup' './database/services/migration' './database/services/monitoring' './monitoring/grafana/dashboards' './monitoring/grafana/datasources' './service_configs/services/node'; \
    for d in \
      '.' \
      './client' \
      './common' \
      './config' \
      './configs' \
      './database' \
      './monitoring' \
      './protocol' \
      './resource_monitor' \
      './security' \
      './server' \
      './server_manager' \
      './service_configs' \
      './session_controller' \
      './common/governance' \
      './common/security' \
