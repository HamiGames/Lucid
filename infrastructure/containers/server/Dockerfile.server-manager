COPY --from=builder --chown=65532:65532 /build/config /app/config
COPY --from=builder --chown=65532:65532 /build/monitoring /app/monitoring
COPY --from=builder --chown=65532:65532 /build/database /app/database
COPY --from=builder --chown=65532:65532 /build/__init__.py /app/__init__.py

COPY --from=builder --chown=65532:65532 /build/service_configs/admin /app/service_configs/admin
COPY --from=builder --chown=65532:65532 /build/service_configs/auth /app/service_configs/auth
COPY --from=builder --chown=65532:65532 /build/service_configs/base /app/service_configs/base
COPY --from=builder --chown=65532:65532 /build/service_configs/blockchain /app/service_configs/blockchain
COPY --from=builder --chown=65532:65532 /build/service_configs/database /app/service_configs/database
COPY --from=builder --chown=65532:65532 /build/service_configs/electron_gui /app/service_configs/electron_gui
COPY --from=builder --chown=65532:65532 /build/service_configs/gui /app/service_configs/gui
COPY --from=builder --chown=65532:65532 /build/service_configs/node /app/service_configs/node
COPY --from=builder --chown=65532:65532 /build/service_configs/payment_systems /app/service_configs/payment_systems
COPY --from=builder --chown=65532:65532 /build/service_configs/rdp /app/service_configs/rdp
COPY --from=builder --chown=65532:65532 /build/service_configs/server /app/service_configs/server
COPY --from=builder --chown=65532:65532 /build/service_configs/services /app/service_configs/services
COPY --from=builder --chown=65532:65532 /build/service_configs/services/node /app/service_configs/services/node
