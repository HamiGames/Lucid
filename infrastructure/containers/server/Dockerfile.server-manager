    done
# LUCID_X_FILES_SKELETON_END

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir --no-index --find-links /build/wheels -r ./requirements.server-manager.txt && \
    pip install --no-cache-dir --no-index --find-links /build/wheels -r ./requirements.security.txt

RUN printf "LUCID_SERVER_OPERATIONS_PACKAGES_$(date +%s)" > /usr/local/lib/python3.11/site-packages/.lucid-marker && \
    chown 65532:65532 /usr/local/lib/python3.11/site-packages/.lucid-marker

RUN python3.11 -c "import fastapi, uvicorn, pydantic, pydantic_settings, motor, redis, cryptography, argon2, passlib; print('server-operations packages OK')"


COPY infrastructure/containers/admin/docker-compose.admin.yml ./service_configs/admin/docker-compose.admin.yml
COPY infrastructure/containers/auth/docker-compose.auth.yml ./service_configs/auth/docker-compose.auth.yml
COPY infrastructure/containers/base/docker-compose.base.yml ./service_configs/base/docker-compose.base.yml
COPY infrastructure/containers/blockchain/docker-compose.chain.yml ./service_configs/blockchain/docker-compose.chain.yml
COPY infrastructure/containers/blockchain/docker-compose.manager.yml ./service_configs/blockchain/docker-compose.manager.yml
COPY infrastructure/containers/database/docker-compose.database-system.yml ./service_configs/database/docker-compose.database-system.yml
COPY infrastructure/containers/electron_gui/docker-compose.electron-gui.yml ./service_configs/electron_gui/docker-compose.electron-gui.yml
COPY infrastructure/containers/gui/docker-compose.gui-admin.yml ./service_configs/gui/docker-compose.gui-admin.yml
COPY infrastructure/containers/gui/docker-compose.node-gui.yml ./service_configs/gui/docker-compose.node-gui.yml
COPY infrastructure/containers/gui/docker-compose.user-gui.yml ./service_configs/gui/docker-compose.user-gui.yml
COPY infrastructure/containers/node/docker-compose.node-data-system.yml ./service_configs/node/docker-compose.node-data-system.yml
COPY infrastructure/containers/node/docker-compose.node-gui.yml ./service_configs/node/docker-compose.node-gui.yml
COPY infrastructure/containers/node/docker-compose.node-images.yml ./service_configs/node/docker-compose.node-images.yml
COPY infrastructure/containers/node/docker-compose.node-sessions.yml ./service_configs/node/docker-compose.node-sessions.yml
COPY infrastructure/containers/payment_systems/docker-compose.payment-externals.yml ./service_configs/payment_systems/docker-compose.payment-externals.yml
COPY infrastructure/containers/payment_systems/docker-compose.payment-internal.yml ./service_configs/payment_systems/docker-compose.payment-internal.yml
COPY infrastructure/containers/rdp/docker-compose.rdp-system.yml ./service_configs/rdp/docker-compose.rdp-system.yml
COPY infrastructure/containers/server/docker-compose.server-external.yml ./service_configs/server/docker-compose.server-external.yml
COPY infrastructure/containers/server/docker-compose.server-images.yml ./service_configs/server/docker-compose.server-images.yml
COPY infrastructure/containers/services/node/docker-compose.node-management.yml ./service_configs/services/node/docker-compose.node-management.yml
COPY infrastructure/containers/sessions/docker-compose.session-images.yml ./service_configs/sessions/docker-compose.session-images.yml
COPY infrastructure/containers/tor/docker-compose.proxy-systems.yml ./service_configs/tor/docker-compose.proxy-systems.yml

# Handler trees: orchestration API + all server subsystems shipped in this image
COPY RDP/server_manager/ ./server_manager/
COPY RDP/server/ ./server/
COPY RDP/session_controller/ ./session_controller/
COPY RDP/protocol/ ./protocol/
COPY RDP/common/ ./common/
COPY RDP/client/ ./client/
COPY RDP/resource_monitor/ ./resource_monitor/
COPY RDP/security/ ./security/
COPY RDP/config/ ./config/
COPY RDP/monitoring/ ./monitoring/
COPY RDP/database/ ./database/
COPY RDP/__init__.py ./__init__.py

RUN printf "LUCID_SERVER_OPS_HANDLER_$(date +%s)" > ./server_manager/.keep && \
    printf "LUCID_SERVER_OPS_HANDLER_$(date +%s)" > ./server/.keep && \
    printf "LUCID_SERVER_OPS_HANDLER_$(date +%s)" > ./session_controller/.keep && \
    printf "LUCID_SERVER_OPS_HANDLER_$(date +%s)" > ./protocol/.keep && \
    printf "LUCID_SERVER_OPS_HANDLER_$(date +%s)" > ./common/.keep && \
    printf "LUCID_SERVER_OPS_HANDLER_$(date +%s)" > ./client/.keep && \
    printf "LUCID_SERVER_OPS_HANDLER_$(date +%s)" > ./resource_monitor/.keep && \
    printf "LUCID_SERVER_OPS_HANDLER_$(date +%s)" > ./security/.keep && \
    printf "LUCID_SERVER_OPS_HANDLER_$(date +%s)" > ./config/.keep && \
    printf "LUCID_SERVER_OPS_HANDLER_$(date +%s)" > ./monitoring/.keep && \
    printf "LUCID_SERVER_OPS_HANDLER_$(date +%s)" > ./database/.keep && \
    chown -R 65532:65532 ./server_manager ./server ./session_controller ./protocol ./common ./client ./resource_monitor ./security ./config ./monitoring ./database ./__init__.py

RUN test -f ./server_manager/main.py && \
    test -f ./server_manager/entrypoint.py && \
    test -f ./session_controller/main.py && \
    test -f ./resource_monitor/main.py && \
    test -f ./security/access_controller.py && \
    echo "server-operations handler trees verified in builder"

############################
# Stage 2 – Runtime (Distroless)
############################
FROM --platform=$TARGETPLATFORM gcr.io/distroless/python3-debian12:latest

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=1.0.0

LABEL maintainer="Lucid Development Team" \
      org.opencontainers.image.title="Lucid Server Operations" \
      org.opencontainers.image.description="Distroless orchestrator for Lucid server subsystem handlers (lifecycle API + bundled handler modules)" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      com.lucid.service="lucid-server-manager" \
      com.lucid.role="server-handler-orchestrator" \
      com.lucid.platform="arm64" \
      com.lucid.cluster="core" \
      com.lucid.security="distroless" \
      com.lucid.expose="8081" \
      com.lucid.hostconfig.registry_key="lucid_server_manager" \
      com.lucid.discovery.host_ip="172.20.10.3"

# LUCID_SERVER_OPERATIONS_PORT: preferred name for this image.
# RDP_SERVER_MANAGER_PORT: retained so server_manager/entrypoint.py and legacy compose keep working.
ENV PATH=/usr/local/bin:/usr/bin:/bin \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app:/usr/local/lib/python3.11/site-packages \
    PYTHONIOENCODING=utf-8 \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    LUCID_HOST_CONFIG_PATH=/app/configs/host-config.yml \
    LUCID_HOST_CONFIG_SERVICE_KEY=lucid_server_manager \
    LUCID_SERVICE_HOST_IP=172.20.10.3 \
    LUCID_SERVICE_HTTP_PATH=http://lucid-server-manager:8081/app \
    LUCID_SERVICES_CONFIG_DIR=/app/service_configs \
    LUCID_SERVER_OPERATIONS_PORT=8081 \
    LUCID_SERVER_OPERATIONS_HOST=0.0.0.0 \
    LUCID_SERVER_MANAGER_HOST_IP=172.20.10.3 \
    RDP_SERVER_MANAGER_PORT=8081 \
    RDP_SERVER_MANAGER_HOST=0.0.0.0 \
    CONSUL_DATACENTER=lucid-dc \
    CONSUL_BOOTSTRAP_EXPECT=1 \
    CONSUL_UI_ENABLED=true \
    CONSUL_CONNECT_ENABLED=true \
    CONSUL_NODE_NAME=lucid-server-manager \
    MONGODB_URI=mongodb://lucid:${MONGODB_PASSWORD}@lucid-mongodb:27017/lucid?authSource=admin \
    REDIS_URL=redis://lucid-redis:6379/0 \
    PROJECT_ROOT=/app \
    PROJECT_NAME=Lucid \
    PROJECT_VERSION=0.1.0 \
    LOG_LEVEL=INFO \
    DEBUG=false \
    LOG_FORMAT=json \
    LUCID_PI_NETWORK=lucid-pi-network \
    LUCID_PI_SUBNET=172.20.0.0/16 \
    LUCID_PI_GATEWAY=172.20.0.1
# LUCID_RUNTIME_COPY_FROM_BUILD_BEGIN
# Generated: same directory set as LUCID_X_FILES_SKELETON (./ under WORKDIR /build).
COPY --from=builder --chown=65532:65532 /build/client/ /app/client/
COPY --from=builder --chown=65532:65532 /build/common/ /app/common/
COPY --from=builder --chown=65532:65532 /build/config/ /app/config/
COPY --from=builder --chown=65532:65532 /build/configs/ /app/configs/
COPY --from=builder --chown=65532:65532 /build/database/ /app/database/
COPY --from=builder --chown=65532:65532 /build/monitoring/ /app/monitoring/
COPY --from=builder --chown=65532:65532 /build/protocol/ /app/protocol/
COPY --from=builder --chown=65532:65532 /build/resource_monitor/ /app/resource_monitor/
COPY --from=builder --chown=65532:65532 /build/security/ /app/security/
COPY --from=builder --chown=65532:65532 /build/server/ /app/server/
COPY --from=builder --chown=65532:65532 /build/server_manager/ /app/server_manager/
COPY --from=builder --chown=65532:65532 /build/service_configs/ /app/service_configs/
COPY --from=builder --chown=65532:65532 /build/session_controller/ /app/session_controller/
# LUCID_RUNTIME_COPY_FROM_BUILD_END

# LUCID_RUNTIME_COPY_FROM_BUILDER_APT_BEGIN
# Generated: apt + RUN scaffold (mkdir/printf/touch/chown) -> FHS (not ./ or /build/; lib_search_and_inject.py).
COPY --from=builder --chown=65532:65532 /usr/lib/*/libffi.so* /app/usr/lib/
COPY --from=builder --chown=65532:65532 /usr/lib/*/libssl.so* /app/usr/lib/
COPY --from=builder --chown=65532:65532 /usr/lib/*/ossl-modules/ /app/usr/lib/
