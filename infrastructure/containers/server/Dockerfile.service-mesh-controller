    pip install --upgrade pip setuptools wheel && \
    echo "pip toolchain upgrade complete" && \
    ls -lh /build/wheels/ | head -20 && \
    echo "total wheels: $(ls -1 /build/wheels/ | wc -l)"

COPY infrastructure/service_mesh/requirements.txt ./requirements.txt
RUN test -f ./requirements.txt

