RUN ["/app/usr/bin/python3.11", "-c", \
    "import os, importlib, importlib.util, sys; \
sp='/app/usr/local/lib/python3.11/site-packages'; bd='/app/usr/local/bin'; \
sys.path.insert(0, sp); \
assert os.path.isdir(sp) and os.path.isdir(bd); \
req=('grpc','aiohttp','consul','pydantic','cryptography','yaml'); \
failed=[p for p in req if importlib.util.find_spec(p) is None]; \
assert not failed, failed; \
[importlib.import_module(p) for p in req]; \
keep=os.path.join(sp,'.keep'); assert os.path.isfile(keep) and os.path.getsize(keep)>0, keep; \
print('✅ runtime site-packages OK')"]

