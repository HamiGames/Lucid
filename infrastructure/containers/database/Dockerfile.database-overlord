# LUCID DATABASE OVERLORD — Distroless Python 3.11
# Hosts templates and HTTP API for database env orchestration.
# API: http://database-overlord:8120/api/v1/database/overlord
# Build context: repository root
# Image example: pickme/lucid-database-overlord:latest-arm64

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=1.0.0
ARG TARGETPLATFORM=linux/arm64
ARG BUILDPLATFORM=linux/amd64

############################
