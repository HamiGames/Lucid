# syntax=docker/dockerfile:1.5
# LUCID SESSION STORAGE SERVICE - Distroless Python Service
# Aligned with 03_api_gateway/Dockerfile (dockerfile-design + Dockerfile-copy-pattern)
# Image: pickme/lucid-session-storage-service:latest-arm64
# Port: 8020

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=1.0.0
ARG TARGETPLATFORM=linux/arm64
ARG BUILDPLATFORM=linux/amd64
ARG PYTHON_VERSION=3.11

############################
# Stage 1 – Builder
############################
FROM --platform=$TARGETPLATFORM python:3.11-slim-bookworm AS builder

ARG BUILDPLATFORM
ARG TARGETPLATFORM
ARG PYTHON_VERSION

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_PREFER_BINARY=1 \
    DEBIAN_FRONTEND=noninteractive

WORKDIR /build

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    rm -rf /var/lib/apt/lists/* && \
    apt-get update --allow-releaseinfo-change && \
    apt-get install -y --no-install-recommends \
        build-essential \
        gcc \
        g++ \
        libffi-dev \
        libssl-dev \
        libzstd-dev \
        liblz4-dev \
        pkg-config \
        curl \
        ca-certificates \
        tini \
        python3-wheel \
        python3-dev \
        python3-pip \
        python3-setuptools \
        rustc \
        cargo \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

RUN mkdir -p /root /root/.rustup /root/.cargo && \
    printf "LUCID_SESSION_STORAGE_RUST_$(date +%s)" > /root/.keep && \
    touch /root/.keep && \
    printf "LUCID_SESSION_STORAGE_RUSTUP_$(date +%s)" > /root/.rustup/.keep && \
    touch /root/.rustup/.keep && \
    printf "LUCID_SESSION_STORAGE_CARGO_$(date +%s)" > /root/.cargo/.keep && \
    touch /root/.cargo/.keep && \
    chown -R 65532:65532 /root /root/.cargo /root/.rustup && \
    chmod +x /root/.keep /root/.rustup/.keep /root/.cargo/.keep

RUN apt-get remove -y rustc cargo && \
    rm -rf /root/.cargo /root/.rustup && \
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable

ENV PATH=/root/.cargo/bin:$PATH

RUN printf "LUCID_SESSION_STORAGE_SERVICE_RUNTIME_DIRECTORY" > /var/run/.keep && \
    printf "LUCID_SESSION_STORAGE_SERVICE_LIB_DIRECTORY" > /var/lib/.keep && \
    chown -R 65532:65532 /var/run /var/lib && \
    chmod 644 /var/run/.keep /var/lib/.keep

RUN mkdir -p /usr /usr/local /usr/local/lib /usr/local/bin /usr/local/lib/python3.11 /usr/local/lib/python3.11/site-packages && \
    printf "LUCID_SESSION_STORAGE_USR_$(date +%s)" > /usr/.keep && \
    touch /usr/.keep && \
    printf "LUCID_SESSION_STORAGE_USR_LOCAL_$(date +%s)" > /usr/local/.keep && \
    touch /usr/local/.keep && \
    printf "LUCID_SESSION_STORAGE_USR_LOCAL_LIB_$(date +%s)" > /usr/local/lib/.keep && \
    touch /usr/local/lib/.keep && \
    printf "LUCID_SESSION_STORAGE_PY311_$(date +%s)" > /usr/local/lib/python3.11/.keep && \
    touch /usr/local/lib/python3.11/.keep && \
    printf "LUCID_SESSION_STORAGE_SITE_PACKAGES_$(date +%s)" > /usr/local/lib/python3.11/site-packages/.keep && \
    touch /usr/local/lib/python3.11/site-packages/.keep && \
    printf "LUCID_SESSION_STORAGE_USR_LOCAL_BIN_$(date +%s)" > /usr/local/bin/.keep && \
    touch /usr/local/bin/.keep && \
    chown -R 65532:65532 /usr /usr/local /usr/local/lib /usr/local/bin /usr/local/lib/python3.11 /usr/local/lib/python3.11/site-packages && \
    chmod 644 /usr/.keep /usr/local/.keep /usr/local/lib/.keep /usr/local/lib/python3.11/.keep /usr/local/lib/python3.11/site-packages/.keep /usr/local/bin/.keep

RUN --mount=type=cache,target=/root/.cache/pip \
    mkdir -p /build/wheels && \
    printf "LUCID_SESSION_STORAGE_BUILD_WHEELS_$(date +%s)" > /build/wheels/.keep && \
    touch /build/wheels/.keep && \
    pip install --upgrade pip setuptools wheel

COPY sessions/requirements.storage.txt ./requirements.txt

RUN --mount=type=cache,target=/root/.cache/pip \
    mkdir -p /build/wheels && \
    pip wheel --no-cache-dir --wheel-dir /build/wheels -r ./requirements.txt

RUN pip install --no-cache-dir --no-index --find-links /build/wheels -r ./requirements.txt

RUN echo "=== Verifying pip installation (session storage) ===" && \
    python3.11 -c "import fastapi, uvicorn, pydantic, motor, pymongo, redis, zstandard, lz4, cryptography, blake3, structlog, prometheus_client; print('✅ Critical packages OK')" && \
    test -d /usr/local/lib/python3.11/site-packages && \
    pip list

RUN mkdir -p ./sessions ./sessions/storage ./sessions/core ./sessions/recorder ./sessions/processor ./sessions/api ./sessions/config ./sessions/integration ./sessions/security ./sessions/pipeline ./tmp ./wheels && \
    printf "LUCID_SESSION_STORAGE_SESSIONS_$(date +%s)" > ./sessions/.keep && \
    touch ./sessions/.keep && \
    printf "LUCID_SESSION_STORAGE_STORAGE_$(date +%s)" > ./sessions/storage/.keep && \
    touch ./sessions/storage/.keep && \
    printf "LUCID_SESSION_STORAGE_TMP_$(date +%s)" > ./tmp/.keep && \
    touch ./tmp/.keep && \
    printf "LUCID_SESSION_STORAGE_CORE_$(date +%s)" > ./sessions/core/.keep && \
    touch ./sessions/core/.keep && \
    printf "LUCID_SESSION_STORAGE_RECORDER_$(date +%s)" > ./sessions/recorder/.keep && \
    touch ./sessions/recorder/.keep && \
    printf "LUCID_SESSION_STORAGE_ENCRYPTION_$(date +%s)" > ./sessions/encryption/.keep && \
    touch ./sessions/encryption/.keep && \
    printf "LUCID_SESSION_STORAGE_PROCESSOR_$(date +%s)" > ./sessions/processor/.keep && \
    touch ./sessions/processor/.keep && \
    printf "LUCID_SESSION_STORAGE_API_$(date +%s)" > ./sessions/api/.keep && \
    touch ./sessions/api/.keep && \
    printf "LUCID_SESSION_STORAGE_CONFIG_$(date +%s)" > ./sessions/config/.keep && \
    touch ./sessions/config/.keep && \
    printf "LUCID_SESSION_STORAGE_INTEGRATION_$(date +%s)" > ./sessions/integration/.keep && \
    touch ./sessions/integration/.keep && \
    printf "LUCID_SESSION_STORAGE_SECURITY_$(date +%s)" > ./sessions/security/.keep && \
    touch ./sessions/security/.keep && \
    printf "LUCID_SESSION_STORAGE_PIPELINE_$(date +%s)" > ./sessions/pipeline/.keep && \
    touch ./sessions/pipeline/.keep && \

COPY sessions/api/ ./sessions/api/
COPY sessions/config/storage-config.yaml ./sessions/config/storage-config.yaml
COPY sessions/config/api-config.yaml ./sessions/config/api-config.yaml

RUN echo "=== Session storage config files ===" && \
    ls -la ./sessions/config/ && \
    chmod +x ./sessions/config/storage-config.yaml && chmod +x ./sessions/config/api-config.yaml && \
    echo "Session storage config files verified"


COPY sessions/integration/ ./sessions/integration/
COPY sessions/security/ ./sessions/security/
COPY sessions/pipeline/ ./sessions/pipeline/
COPY sessions/core/ ./sessions/core/
COPY sessions/encryption/ ./sessions/encryption/
COPY sessions/processor/ ./sessions/processor/
COPY sessions/recorder/ ./sessions/recorder/
COPY sessions/storage/ ./sessions/storage/

RUN echo "changing permissions for session storage files" && \
    chmod +x ./sessions/integration/* && \
    chmod +x ./sessions/security/* && \
    chmod +x ./sessions/pipeline/* && \
    chmod +x ./sessions/core/* && \
    chmod +x ./sessions/encryption/* && \
    chmod +x ./sessions/processor/* && \
    chmod +x ./sessions/recorder/* && \
    chmod +x ./sessions/storage/* && \
    echo "Session storage files permissions changed"


COPY sessions/__init__.py ./sessions/__init__.py
COPY sessions/chunk_manager.py ./sessions/chunk_manager.py

RUN echo "sessions files copied + activated" && \
    ls -la ./sessions/ && \
    chmod +x ./sessions/* && \
    echo "sessions files verified"

RUN mkdir -p ./tmp

COPY <<'PY' ./tmp/verify_runtime_session_storage.py
import os
import sys

dirs = [
    "/app/sessions",
    "/app/sessions/storage",
    "/app/usr/local/lib/python3.11/site-packages",
    "/app/wheels",
]
for d in dirs:
    if not os.path.isdir(d):
        print(f"ERROR: {d} missing")
        sys.exit(1)
    if d.endswith("site-packages") and not os.listdir(d):
        print(f"ERROR: {d} empty")
        sys.exit(1)
print("✅ Session storage runtime layout verified")
PY

RUN chmod +x ./tmp/verify_runtime_session_storage.py


############################
# Stage 2 – Runtime (Distroless)
############################
FROM --platform=$TARGETPLATFORM gcr.io/distroless/python3-debian12:latest

WORKDIR /app

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=1.0.0

LABEL maintainer="Lucid Development Team" \
      org.opencontainers.image.title="Lucid Session Storage Service" \
      org.opencontainers.image.description="Distroless Session Storage Service for Lucid project" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      com.lucid.service="session-storage-service" \
      com.lucid.platform="arm64" \
      com.lucid.cluster="storage" \
      com.lucid.security="distroless"

ENV PATH=/app/usr/local/bin:/app/usr/bin:/app/bin:$PATH \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app:/app/usr/local/lib/python3.11/site-packages \
    PYTHONIOENCODING=utf-8 \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    SESSION_STORAGE_SERVICE_PORT=8020

COPY --from=builder /root/.rustup/ /app/rust/
COPY --from=builder /root/.cargo/ /app/cargo/
COPY --from=builder /var/run/ /app/var/run/
COPY --from=builder /var/lib/ /app/var/lib/
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /app/etc/ssl/certs/ca-certificates.crt
COPY --from=builder /usr/local/lib/python3.11/site-packages/ /app/usr/local/lib/python3.11/site-packages/
COPY --from=builder /usr/local/bin/ /app/usr/local/bin/
COPY --from=builder /usr/bin/ /app/usr/bin/
COPY --from=builder /usr/sbin/ /app/usr/sbin/

COPY --from=builder --chown=65532:65532 /build/wheels/ /app/wheels/
COPY --from=builder --chown=65532:65532 /build/sessions/ /app/sessions/
COPY --from=builder --chown=65532:65532 /build/tmp/verify_runtime_session_storage.py /app/tmp/verify_runtime.py


COPY --from=builder --chown=65532:65532 /build/sessions/chunk_manager.py /app/sessions/chunk_manager.py
COPY --from=builder --chown=65532:65532 /build/sessions/__init__.py /app/sessions/__init__.py
COPY --from=builder --chown=65532:65532 /build/sessions/storage/ /app/sessions/storage/
COPY --from=builder --chown=65532:65532 /build/sessions/core/ /app/sessions/core/
COPY --from=builder --chown=65532:65532 /build/sessions/recorder/ /app/sessions/recorder/
COPY --from=builder --chown=65532:65532 /build/sessions/encryption/ /app/sessions/encryption/
COPY --from=builder --chown=65532:65532 /build/sessions/processor/ /app/sessions/processor/
COPY --from=builder --chown=65532:65532 /build/sessions/api/ /app/sessions/api/
COPY --from=builder --chown=65532:65532 /build/sessions/config/ /app/sessions/config/
COPY --from=builder --chown=65532:65532 /build/sessions/integration/ /app/sessions/integration/
COPY --from=builder --chown=65532:65532 /build/sessions/security/ /app/sessions/security/
COPY --from=builder --chown=65532:65532 /build/sessions/pipeline/ /app/sessions/pipeline/


RUN ["/app/usr/bin/python3.11", "/app/tmp/verify_runtime.py"]
RUN ["rm", "-f", "/app/tmp/verify_runtime.py"]

EXPOSE 8020

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD ["/app/usr/bin/python3.11", "-c", "import urllib.request; urllib.request.urlopen('http://session-storage-service:8020/health', timeout=2); exit(0)"]

USER 65532:65532

ENTRYPOINT ["/app/usr/bin/tini", "--"]

CMD ["/app/usr/bin/python3.11", "-m", "uvicorn", "sessions.storage.main:app", "--host", "session-storage-service", "--port", "8020"]
