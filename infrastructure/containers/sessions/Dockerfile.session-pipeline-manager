# syntax=docker/dockerfile:1.5
# LUCID SESSION PIPELINE MANAGER - Distroless Python Service
# creates session-pipeline-manager service
# Image: pickme/lucid-session-pipeline-manager:latest-arm64
# Port: 7990

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=1.0.0
ARG TARGETPLATFORM=linux/arm64
ARG BUILDPLATFORM=linux/amd64
ARG PYTHON_VERSION=3.11

############################
# Stage 1 – Builder
############################
FROM --platform=$TARGETPLATFORM python:3.11-slim-bookworm AS builder

ARG BUILDPLATFORM
ARG TARGETPLATFORM
ARG PYTHON_VERSION

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_PREFER_BINARY=1 \
    DEBIAN_FRONTEND=noninteractive

WORKDIR /build

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    rm -rf /var/lib/apt/lists/* && \
    apt-get update --allow-releaseinfo-change && \
    apt-get install -y --no-install-recommends \
        build-essential \
        gcc \
        g++ \
        libffi-dev \
        libssl-dev \
        pkg-config \
        curl \
        ca-certificates \
        tini \
        python3-wheel \
        python3-dev \
        python3-pip \
        python3-setuptools \
        rustc \
        cargo \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

RUN mkdir -p /root /root/.rustup /root/.cargo && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_RUST_$(date +%s)" > /root/.keep && \
    touch /root/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_RUSTUP_$(date +%s)" > /root/.rustup/.keep && \
    touch /root/.rustup/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_CARGO_$(date +%s)" > /root/.cargo/.keep && \
    touch /root/.cargo/.keep && \
    chown -R 65532:65532 /root /root/.cargo /root/.rustup && \
    chmod +x /root/.keep /root/.rustup/.keep /root/.cargo/.keep

RUN apt-get update --allow-releaseinfo-change && \
    apt-get remove -y rustc cargo && \
    rm -rf /root/.cargo /root/.rustup && \
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

ENV PATH=/root/.cargo/bin:$PATH

RUN printf "LUCID_SESSION_PIPELINE_MANAGER_RUNTIME_DIRECTORY" > /var/run/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_LIB_DIRECTORY" > /var/lib/.keep && \
    chown -R 65532:65532 /var/run /var/lib && \
    chmod 644 /var/run/.keep /var/lib/.keep

RUN mkdir -p /usr /usr/local /usr/local/lib /usr/local/bin /usr/local/lib/python3.11 /usr/local/lib/python3.11/site-packages && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_USR_$(date +%s)" > /usr/.keep && \
    touch /usr/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_USR_LOCAL_$(date +%s)" > /usr/local/.keep && \
    touch /usr/local/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_USR_LOCAL_LIB_$(date +%s)" > /usr/local/lib/.keep && \
    touch /usr/local/lib/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_PY311_$(date +%s)" > /usr/local/lib/python3.11/.keep && \
    touch /usr/local/lib/python3.11/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_SITE_PACKAGES_$(date +%s)" > /usr/local/lib/python3.11/site-packages/.keep && \
    touch /usr/local/lib/python3.11/site-packages/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_USR_LOCAL_BIN_$(date +%s)" > /usr/local/bin/.keep && \
    touch /usr/local/bin/.keep && \
    chown -R 65532:65532 /usr /usr/local /usr/local/lib /usr/local/bin /usr/local/lib/python3.11 /usr/local/lib/python3.11/site-packages && \
    chmod 644 /usr/.keep /usr/local/.keep /usr/local/lib/.keep /usr/local/lib/python3.11/.keep /usr/local/lib/python3.11/site-packages/.keep /usr/local/bin/.keep

RUN --mount=type=cache,target=/root/.cache/pip \
    mkdir -p /build/wheels && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_BUILD_WHEELS_$(date +%s)" > /build/wheels/.keep && \
    touch /build/wheels/.keep && \
    pip install --upgrade pip setuptools wheel

COPY sessions/requirements.pipeline.txt ./requirements.txt

RUN --mount=type=cache,target=/root/.cache/pip \
    mkdir -p /build/wheels && \
    pip wheel --no-cache-dir --wheel-dir /build/wheels -r ./requirements.txt

RUN pip install --no-cache-dir --no-index --find-links /build/wheels -r ./requirements.txt

RUN echo "=== Verifying pip installation (session pipeline manager) ===" && \
    python3.11 -c "import fastapi, uvicorn, pydantic, httpx, aiohttp, motor, pymongo, zstandard, cryptography, blake3, structlog, prometheus_client; print('✅ Critical packages OK')" && \
    test -d /usr/local/lib/python3.11/site-packages && \
    pip list

RUN mkdir -p ./sessions ./sessions/pipeline ./sessions/core ./common/tor ./sessions/processor ./common ./common/governance ./sessions/recorder ./sessions/storage ./sessions/config ./sessions/security ./tmp ./wheels && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_SESSIONS_$(date +%s)" > ./sessions/.keep && \
    touch ./sessions/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_TMP_$(date +%s)" > ./tmp/.keep && \
    touch ./tmp/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_PIPELINE_$(date +%s)" > ./sessions/pipeline/.keep && \
    touch ./sessions/pipeline/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_CORE_$(date +%s)" > ./sessions/core/.keep && \
    touch ./sessions/core/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_PROCESSOR_$(date +%s)" > ./sessions/processor/.keep && \
    touch ./sessions/processor/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_RECORDER_$(date +%s)" > ./sessions/recorder/.keep && \
    touch ./sessions/recorder/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_STORAGE_$(date +%s)" > ./sessions/storage/.keep && \
    touch ./sessions/storage/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_CONFIG_$(date +%s)" > ./sessions/config/.keep && \
    touch ./sessions/config/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_SECURITY_$(date +%s)" > ./sessions/security/.keep && \
    touch ./sessions/security/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_COMMON_$(date +%s)" > ./common/.keep && \
    touch ./common/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_COMMON_GOVERNANCE_$(date +%s)" > ./common/governance/.keep && \
    touch ./common/governance/.keep && \
    printf "LUCID_SESSION_PIPELINE_MANAGER_COMMON_TOR_$(date +%s)" > ./common/tor/.keep && \
    touch ./common/tor/.keep && \
    chown -R 65532:65532 ./sessions ./common ./tmp && \
    chmod 644 ./sessions/.keep ./tmp/.keep ./common/.keep ./common/governance/.keep ./common/tor/.keep

COPY common/__init__.py ./common/__init__.py
COPY common/governance/lucid_governor.py ./common/governance/lucid_governor.py
COPY common/governance/param_registry.py ./common/governance/param_registry.py
COPY common/governance/timelock.py ./common/governance/timelock.py
COPY common/tor/ ./common/tor/

COPY sessions/__init__.py ./sessions/__init__.py
COPY sessions/pipeline/ ./sessions/pipeline/
COPY sessions/core/ ./sessions/core/
COPY sessions/processor/ ./sessions/processor/
COPY sessions/recorder/ ./sessions/recorder/
COPY sessions/storage/ ./sessions/storage/
COPY sessions/config/pipeline-config.yaml ./sessions/config/pipeline-config.yaml
COPY sessions/config/api-config.yaml ./sessions/config/api-config.yaml

COPY sessions/security/ ./sessions/security/

RUN chmod +x ./sessions/pipeline/* && \
    chmod +x ./sessions/core/* && \
    chmod +x ./sessions/processor/* && \
    chmod +x ./sessions/recorder/* && \
    chmod +x ./sessions/storage/* && \
    chmod +x ./sessions/config/* && \
    chmod +x ./sessions/security/* && \
    chmod +x ./sessions/* && \
    chmod +x ./common/* && \
    chmod +x ./common/governance/* 2>/dev/null || true && \
    echo "Session pipeline manager files permissions changed"


COPY <<'PY' ./tmp/verify_runtime.py
import os
import sys

dirs = [
    "/app/sessions",
    "/app/sessions/pipeline",
    "/app/sessions/core",
    "/app/sessions/processor",
    "/app/usr/local/lib/python3.11/site-packages",
    "/app/wheels",
]
for d in dirs:
    if not os.path.isdir(d):
        print(f"ERROR: {d} missing")
        sys.exit(1)
    if d.endswith("site-packages") and not os.listdir(d):
        print(f"ERROR: {d} empty")
        sys.exit(1)
print("✅ Session pipeline manager runtime layout verified")
PY

############################
# Stage 2 – Runtime (Distroless)
############################
FROM --platform=$TARGETPLATFORM gcr.io/distroless/python3-debian12:latest

WORKDIR /app

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=1.0.0

LABEL maintainer="Lucid Development Team" \
      org.opencontainers.image.title="Lucid Session Pipeline Manager" \
      org.opencontainers.image.description="Distroless Session Pipeline Manager for Lucid project" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      com.lucid.service="session-pipeline-manager" \
      com.lucid.platform="arm64" \
      com.lucid.cluster="processing" \
      com.lucid.security="distroless" \
      com.lucid.api.gateway="api-gateway"

ENV PATH=/app/usr/local/bin:/app/usr/bin:/app/bin:$PATH \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app:/app/usr/local/lib/python3.11/site-packages \
    PYTHONIOENCODING=utf-8 \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    SESSION_PIPELINE_MANAGER_PORT=7990

COPY --from=builder --chown=65532:65532 /root/.rustup/ /app/rust/
COPY --from=builder --chown=65532:65532 /root/.cargo/ /app/cargo/
COPY --from=builder --chown=65532:65532 /var/run/ /app/var/run/
COPY --from=builder --chown=65532:65532 /var/lib/ /app/var/lib/
COPY --from=builder --chown=65532:65532 /etc/ssl/certs/ca-certificates.crt /app/etc/ssl/certs/ca-certificates.crt
COPY --from=builder --chown=65532:65532 /usr/local/lib/python3.11/site-packages/ /app/usr/local/lib/python3.11/site-packages/
COPY --from=builder --chown=65532:65532 /usr/local/bin/ /app/usr/local/bin/
COPY --from=builder --chown=65532:65532 /usr/bin/ /app/usr/bin/
COPY --from=builder --chown=65532:65532 /usr/sbin/ /app/usr/sbin/

COPY --from=builder --chown=65532:65532 /build/wheels/ /app/wheels/
COPY --from=builder --chown=65532:65532 /build/sessions/ /app/sessions/
COPY --from=builder --chown=65532:65532 /build/tmp/verify_runtime.py /app/tmp/verify_runtime.py


COPY --from=builder --chown=65532:65532 /build/common/__init__.py /app/common/__init__.py
COPY --from=builder --chown=65532:65532 /build/common/governance/lucid_governor.py /app/common/governance/lucid_governor.py
COPY --from=builder --chown=65532:65532 /build/common/governance/param_registry.py /app/common/governance/param_registry.py
COPY --from=builder --chown=65532:65532 /build/common/governance/timelock.py /app/common/governance/timelock.py

COPY --from=builder --chown=65532:65532 /build/sessions/__init__.py /app/sessions/__init__.py
COPY --from=builder --chown=65532:65532 /build/sessions/pipeline/ /app/sessions/pipeline/
COPY --from=builder --chown=65532:65532 /build/sessions/core/ /app/sessions/core/
COPY --from=builder --chown=65532:65532 /build/sessions/processor/ /app/sessions/processor/
COPY --from=builder --chown=65532:65532 /build/sessions/recorder/ /app/sessions/recorder/
COPY --from=builder --chown=65532:65532 /build/sessions/storage/ /app/sessions/storage/
COPY --from=builder --chown=65532:65532 /build/sessions/config/ /app/sessions/config/
COPY --from=builder --chown=65532:65532 /build/sessions/security/ /app/sessions/security/

COPY --from=builder --chown=65532:65532 /build/common/tor/ /app/common/tor/



RUN ["/app/usr/bin/python3.11", "/app/tmp/verify_runtime.py"]

RUN ["rm", "-f", "/app/tmp/verify_runtime.py"]

EXPOSE 7990

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD ["/app/usr/bin/python3.11", "-c", "import urllib.request; urllib.request.urlopen('http://session-pipeline-manager:7990/health', timeout=2).read()"]

USER 65532:65532

ENTRYPOINT ["/app/usr/bin/tini", "--"]

CMD ["/app/usr/bin/python3.11", "-m", "uvicorn", "sessions.pipeline.main:app", "--host", "session-pipeline-manager", "--port", "7990"]
