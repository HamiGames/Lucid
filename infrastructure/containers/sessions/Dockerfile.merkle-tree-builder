RUN echo "=== Verifying pip installation (merkle tree builder / processor stack) ===" && \
    python3.11 -c "import blake3, zstandard, lz4, brotli, cryptography, fastapi, uvicorn, motor, pymongo, redis, numpy, httpx, aiohttp, structlog, prometheus_client; print('✅ All critical packages installed')" && \
    test -d /usr/local/lib/python3.11/site-packages && \
    pip list


COPY sessions/pipeline/ ./sessions/pipeline/
COPY sessions/processor/ ./sessions/processor/
COPY sessions/recorder/ ./sessions/recorder/
COPY sessions/storage/ ./sessions/storage/
COPY sessions/api/ ./sessions/api/
COPY sessions/config/ ./sessions/config/
COPY sessions/integration/ ./sessions/integration/
COPY sessions/security/ ./sessions/security/
COPY sessions/core/ ./sessions/core/
COPY sessions/encryption/ ./sessions/encryption/
COPY sessions/__init__.py ./sessions/__init__.py

COPY blockchain/ ./blockchain/
COPY database/ ./database/
COPY infrastructure/containers/services/ ./service_configs/
COPY master-env-config.txt ./configs/.env.master
COPY configs/environment/.env.secrets ./configs/.env.secrets
COPY infrastructure/containers/host-config.yml ./service_configs/host-config.yml
COPY infrastructure/containers/services/x_lucid_cluster_calibration/processing-cluster-host-alignment.yml ./service_configs/x_lucid_cluster_calibration/processing-cluster-host-alignment.yml
RUN cp -f ./service_configs/session-management.yml ./config/session-management.yml

RUN test -d ./sessions/pipeline && test -d ./blockchain && test -f ./config/session-management.yml && \
    python3.11 -c "import sys; sys.path.insert(0, '/build'); import os; assert os.path.isdir('/build/sessions/processor'); print('✅ Merkle builder source tree OK')"


COPY <<'PY' /build/tmp/verify_runtime.py
import os
import sys

dirs = [
    "/app/sessions",
    "/app/sessions/pipeline",
    "/app/sessions/processor",
    "/app/sessions/core",
    "/app/blockchain",
    "/app/database",
    "/app/config",
    "/app/service_configs",
    "/app/usr/local/lib/python3.11/site-packages",
