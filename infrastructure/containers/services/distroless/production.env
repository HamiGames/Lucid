# Lucid Project - Distroless Production Environment Configuration
# Aligned with ports.txt + master-env-config.txt; static host_ip map: infrastructure/containers/host-config.yml + repository root service-ip.txt
# Secrets from configs/environment/.env.secrets → /app/configs/.env.secrets

# =============================================================================
# CORE SERVICE CONNECTIONS
# =============================================================================

# MongoDB Configuration (ports.txt lucid_mongodb:27017)
MONGODB_URI=mongodb://lucid:lucid@lucid-mongodb:27017/lucid?authSource=admin&retryWrites=false&directConnection=true
MONGO_URI=mongodb://lucid:lucid@lucid-mongodb:27017/lucid?authSource=admin&retryWrites=false&directConnection=true
MONGO_URL=mongodb://lucid:lucid@lucid-mongodb:27017/lucid?authSource=admin&retryWrites=false&directConnection=true

# Blockchain Core Service (ports.txt blockchain_engine:8084, data_chain:8087)
BLOCKCHAIN_CORE_URL=http://blockchain-engine:8084
BLOCKCHAIN_API_URL=http://data-chain:8087

# On-System Chain RPC (override via .env.secrets if using external JSON-RPC)
ON_SYSTEM_CHAIN_RPC=http://on-system-chain-client:8040
ON_CHAIN_RPC_URL=http://on-system-chain-client:8040

# =============================================================================
# TOR ONION SERVICE CONNECTIONS
# =============================================================================

# Tor Onion Service Addresses (from pickme/lucid:tor-onion)
TOR_ONION_BLOCKCHAIN_CORE=blockchain-core-xyz123.onion
TOR_ONION_BLOCKCHAIN_API=blockchain-api-abc456.onion
TOR_ONION_AUTHENTICATION=auth-service-def789.onion
TOR_ONION_ADMIN_UI=admin-ui-ghi012.onion
TOR_ONION_NODE_MANAGER=node-manager-jkl345.onion
TOR_ONION_RDP_SERVER=rdp-server-mno678.onion
TOR_ONION_SESSION_MANAGER=session-mgr-pqr901.onion
TOR_ONION_STORAGE_SERVICE=storage-svc-stu234.onion

# Perspective Onion Addresses
PERSPECTIVE_ONION_BLOCKCHAIN=perspective-blockchain-xyz123.onion
PERSPECTIVE_ONION_AUTH=perspective-auth-abc456.onion
PERSPECTIVE_ONION_ADMIN=perspective-admin-def789.onion
PERSPECTIVE_ONION_NODE=perspective-node-ghi012.onion
PERSPECTIVE_ONION_RDP=perspective-rdp-jkl345.onion

# =============================================================================
# SERVICE INTERNAL CONNECTIONS
# =============================================================================

# API Gateway (ports.txt main_lucid_gateway)
API_GATEWAY_URL=http://api-gateway:8080
NEXT_PUBLIC_API_URL=http://api-gateway:8080

# Authentication Service (ports.txt lucid_auth_service:8089)
AUTH_SERVICE_URL=http://lucid-auth-service:8089
AUTHENTICATION_URL=http://lucid-auth-service:8089

# Admin UI / backend (master-env ADMIN_INTERFACE_URL)
ADMIN_UI_URL=http://lucid-admin-ui:3000
ADMIN_SERVICE_URL=http://admin-ui-backend:8120

# Node management (ports.txt node_management:8095)
NODE_MANAGER_URL=http://node-management:8095
NODE_API_URL=http://node-management:8095

# RDP Services (ports.txt rdp_server:8001, xrdp desktop xrdp-rdp:3389)
RDP_SERVER_URL=http://rdp-server:8001
RDP_CLIENT_URL=http://rdp-server:8001

# Session API (ports.txt session_api:8113)
SESSION_MANAGER_URL=http://session-api:8113
SESSION_SERVICE_URL=http://session-api:8113

# Session storage service (ports.txt session_storage_service:8020)
STORAGE_SERVICE_URL=http://session-storage-service:8020
STORAGE_MANAGER_URL=http://session-storage-service:8020

# =============================================================================
# TRON BLOCKCHAIN CONNECTIONS
# =============================================================================

# TRON Network Configuration
TRON_NETWORK=mainnet
TRON_HTTP_ENDPOINT=https://api.trongrid.io
TRONGRID_API_KEY=${TRONGRID_API_KEY}

# TRON Contract Addresses
USDT_TRC20_MAINNET=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
USDT_TRC20_SHASTA=TG3XXyExBkPp9nzdajDZsozEu4BkaSJozs

# =============================================================================
# TOR CONFIGURATION
# =============================================================================

# Tor SOCKS Proxy
TOR_SOCKS_HOST=tor-proxy-distroless
TOR_SOCKS_PORT=9050
TOR_SOCKS_URL=socks5://tor-proxy-distroless:9050

# Tor Control Port
TOR_CONTROL_HOST=tor-proxy-distroless
TOR_CONTROL_PORT=9051
TOR_CONTROL_PASSWORD=${TOR_CONTROL_PASSWORD}

# Tor HTTP Proxy (Privoxy)
TOR_HTTP_PROXY_HOST=privoxy-distroless
TOR_HTTP_PROXY_PORT=8118
TOR_HTTP_PROXY_URL=http://privoxy-distroless:8118

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Encryption Keys
KEY_ENC_SECRET=${KEY_ENC_SECRET}
ENCRYPTION_KEY=${ENCRYPTION_KEY}
JWT_SECRET=${JWT_SECRET}

# Hardware Wallet Configuration
HARDWARE_WALLET_ENABLED=true
LEDGER_ENABLED=true
TREZOR_ENABLED=true
KEEPKEY_ENABLED=true

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Network Mode
NETWORK_MODE=distroless
NETWORK_NAME=lucid-distroless-network
SUBNET=172.20.0.0/16
GATEWAY=172.20.0.1

# Service Discovery (ports.txt lucid_service_mesh_controller:8500)
SERVICE_DISCOVERY_ENABLED=true
CONSUL_HOST=lucid-service-mesh-controller
CONSUL_PORT=8500

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_HOST=prometheus-metrics
PROMETHEUS_PORT=9090

GRAFANA_ENABLED=true
GRAFANA_HOST=grafana-distroless
GRAFANA_PORT=3000

# =============================================================================
# RESOURCE LIMITS
# =============================================================================

# Memory Limits
MEMORY_LIMIT=512M
MEMORY_RESERVATION=256M

# CPU Limits
CPU_LIMIT=0.5
CPU_RESERVATION=0.25

# =============================================================================
# HEALTH CHECKS
# =============================================================================

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=10s

# =============================================================================
# VOLUME CONFIGURATION
# =============================================================================

# Data Volumes
DATA_VOLUME=/opt/lucid/data
LOG_VOLUME=/opt/lucid/logs
CACHE_VOLUME=/opt/lucid/cache
CONFIG_VOLUME=/opt/lucid/config
LUCID_ENV_SECRETS_FILE=/app/configs/.env.secrets
LUCID_ENV_MASTER_FILE=/app/configs/.env.master

# =============================================================================
# USER CONFIGURATION
# =============================================================================

# User/Group IDs
USER_ID=1000
GROUP_ID=1000
WORKING_DIR=/app

# =============================================================================
# SECURITY HARDENING
# =============================================================================

# Security Mode
SECURITY_MODE=distroless
SECURITY_SCAN=true
SECURITY_HARDENING=true
NO_NEW_PRIVILEGES=true
READ_ONLY=true

# Capabilities
DROP_CAPABILITIES=ALL
ADD_CAPABILITIES=NET_BIND_SERVICE

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================

# Development Mode (set to false for production)
DEV_MODE=false
DEBUG_MODE=false
MOCK_SERVICES=false
PLACEHOLDER_MODE=false
