COPY --from=builder --chown=65532:65532 /build/service_configs/x_lucid_cluster_calibration/core-cluster-host-alignment.yml /app/service_configs/x_lucid_cluster_calibration/core-cluster-host-alignment.yml




COPY infrastructure/containers/blockchain/verify_runtime.py /app/verify_runtime.py

RUN ["/app/usr/bin/python3.11", "-c", "import os,sys; sp='/app/usr/local/lib/python3.11/site-packages'; sys.path.insert(0,sp); assert os.path.isdir(sp); m=os.path.join(sp,'.keep'); ok=os.path.isfile(m) or os.path.isfile(os.path.join(sp,'.lucid-marker')); assert ok; import uvicorn,fastapi; print('runtime OK')"]

RUN ["/app/usr/bin/python3.11", "/app/verify_runtime.py"]

EXPOSE 8085

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD ["/app/usr/bin/python3.11", "-c", "import os,socket,sys; p=int(os.getenv('BLOCKCHAIN_ENGINE_PORT','8085')); s=socket.socket(); s.settimeout(2); r=s.connect_ex(('127.0.0.1',p)); s.close(); sys.exit(0 if r==0 else 1)"]

USER 65532:65532

ENTRYPOINT ["/app/usr/bin/tini", "--"]

CMD ["/app/usr/bin/python3.11", "/app/api/app/entrypoint.py"]
