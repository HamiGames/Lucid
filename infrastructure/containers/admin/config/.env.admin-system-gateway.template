# Lucid Admin System Gateway — copy to configs/environment/.env.admin-system-gateway (or merge into compose env_file)
# Build host: Windows 11 | Target: Raspberry Pi (arm64)
# Image: pickme/lucid-admin-system-gateway:latest-arm64 (Dockerfile.admin-system-gateway, aligned with 03_api_gateway/Dockerfile)

# Core paths (defaults match distroless /app/node layout)
ADMIN_GATEWAY_OPENSSL_API_YAML=/app/node/config/openssl-api.yml
ADMIN_GATEWAY_CONNECTIONS_JSON=/app/node/config/connections.json

# Health JSON (plain HTTP)
ADMIN_GATEWAY_HEALTH_PORT=8155
ADMIN_GATEWAY_HEALTH_BIND=0.0.0.0

# Global TLS file overrides (see openssl-api.yml)
ADMIN_GATEWAY_SSL_CA_FILE=
ADMIN_GATEWAY_SSL_CERT_FILE=
ADMIN_GATEWAY_SSL_KEY_FILE=

# Per-route upstream overrides (optional). Pattern: ADMIN_GATEWAY_UPSTREAM_<ROUTE_NAME>_HOST / _PORT
# Route names match connections.json "name" in UPPER_SNAKE (non-alnum folded to _)
ADMIN_GATEWAY_UPSTREAM_API_GATEWAY_HOST=api-gateway
ADMIN_GATEWAY_UPSTREAM_API_GATEWAY_PORT=8080
ADMIN_GATEWAY_UPSTREAM_ADMIN_UI_BACKEND_HOST=admin-ui-backend
ADMIN_GATEWAY_UPSTREAM_ADMIN_UI_BACKEND_PORT=8120
ADMIN_GATEWAY_UPSTREAM_ADMIN_PARAMS_REGISTRY_HOST=admin-params-registry
ADMIN_GATEWAY_UPSTREAM_ADMIN_PARAMS_REGISTRY_PORT=8050
ADMIN_GATEWAY_UPSTREAM_TUNNEL_TOOLS_METRICS_HOST=lucid-tunnel-tools
ADMIN_GATEWAY_UPSTREAM_TUNNEL_TOOLS_METRICS_PORT=7000
