# Aligned with 03_api_gateway/Dockerfile (wheels, markers, /app/usr layout, tini)
# host-config: admin-ui-backend; ops: infrastructure/containers/admin/docker-compose.admin.yml
# Build context: repository root (.)
# Image: pickme/lucid-admin-ui-backend:latest-arm64
# Port: 8120
#
# Entrypoint: admin/entrypoint.py → uvicorn admin.main:app
# Tier URLs (compose / env): LUCID_SERVER_CORE_URL, LUCID_SERVER_OPERATIONS_URL, LUCID_RDP_MANAGER_URL

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=1.0.0
ARG TARGETPLATFORM=linux/arm64
ARG BUILDPLATFORM=linux/amd64
ARG PYTHON_VERSION=3.11

############################
