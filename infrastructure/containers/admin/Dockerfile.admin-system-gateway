    printf "LUCID_ADMIN_GATEWAY_WHEELS_$(date +%s)" > /build/wheels/.keep && \
    touch /build/wheels/.keep && \
    pip install --upgrade pip setuptools wheel

COPY infrastructure/containers/admin/requirements.txt ./requirements.txt

