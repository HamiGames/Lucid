# =============================================================================
# Lucid admin plane — baseline template for .env.admin
# Path: infrastructure/containers/overlord/runtime/templates/env.admin.template
#
# Usage:
#   Copy to configs/environment/.env.admin and merge with .env.foundation,
#   .env.core, .env.secrets, and .env.admin-interface as needed.
#
# References:
#   - admin/over_lord/docker-compose.yml (admin stack build references)
#   - admin/env.admin-interface.template (full admin UI env)
# =============================================================================

# =============================================================================
# OVERLORD / DISCOVERY
# =============================================================================
LUCID_ADMIN_OVERLORD=1
ADMIN_OVERLORD_PORT=8140

# =============================================================================
# ADMIN STACK — ports align with infrastructure/containers/admin Dockerfiles
# =============================================================================
ADMIN_INTERFACE_PORT=8120
PARAMS_REGISTRY_PORT=8050
KEY_ROTATION_PORT=8060
GOVERNANCE_CLIENT_PORT=8070

LUCID_ENV=production
LUCID_PLATFORM=arm64
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
