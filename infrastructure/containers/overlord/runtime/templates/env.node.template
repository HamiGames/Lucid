# =============================================================================
# Lucid node plane — baseline template for .env.node
# Path: infrastructure/containers/overlord/runtime/templates/env.node.template
#
# Usage:
#   Copy to configs/environment/.env.node and merge with .env.foundation,
#   .env.core, and .env.secrets. Node Management (8095/8099) uses a separate
#   file: copy node/config/env.node-management.template → .env.node-management
#
# References:
#   - node/docker-compose.yml (lucid-mongodb env_file includes .env.node)
#   - infrastructure/containers/node/docker-compose.node-images.yml
# =============================================================================

# =============================================================================
# OVERLORD / DISCOVERY
# =============================================================================
LUCID_NODE_OVERLORD=1
NODE_OVERLORD_PORT=8130

# =============================================================================
# SHARED RUNTIME (all node-plane app containers: worker, registry, gov, utils)
# =============================================================================
LUCID_ENV=production
LUCID_PLATFORM=arm64
LUCID_CLUSTER=application
LOG_LEVEL=INFO
LOG_FORMAT=json
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Staging port reference (node-management staging; shared label in compose)
NODE_MANAGEMENT_STAGING_PORT=8099

# =============================================================================
# MONGODB & REDIS — required for node-worker / registry / gov / utils
# Passwords from .env.secrets (MONGODB_PASSWORD, REDIS_PASSWORD)
# =============================================================================
MONGODB_URL=mongodb://lucid:${MONGODB_PASSWORD}@lucid-mongodb:27017/lucid_node_management?authSource=admin
MONGODB_DATABASE=lucid_node_management
MONGODB_HOST=lucid-mongodb
MONGODB_PORT=27017

REDIS_URL=redis://:${REDIS_PASSWORD}@lucid-redis:6379/0
REDIS_HOST=lucid-redis
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# NODE / MONGO COMPOSE (node/docker-compose.yml — env merged into lucid-mongodb)
# Aligns with plan/instructions/environment-variables-reference.md
# =============================================================================
SERVICE_NAME=node
SERVICE_PORT=8099
SERVICE_HOST=172.20.0.29
SERVICE_URL=http://172.20.0.29:8099
NODE_ID=node-001
NODE_REGION=us-east

# =============================================================================
# OPTIONAL — local image compose (infrastructure/containers/node/docker-compose.node-images.yml)
# =============================================================================
LUCID_NODE_IMAGES_PLATFORM=linux/arm64
LUCID_NODE_IMAGES_MONGO_PORT=27017
LUCID_NODE_IMAGES_REDIS_PORT=6379

# Per-service identity when using compose substitution (no duplicate keys in one file):
#   NODE_WORKER_ID=node-worker-1
#   NODE_REGISTRY_ID=node-registry-1
#   NODE_GOV_ID=node-gov-1
#   NODE_UTILS_ID=node-utils-1

# =============================================================================
# PER-SERVICE BIND / URL — set ONLY on the matching compose service (not all at once)
# Duplicate keys are invalid in a single .env; use compose `environment:` or split files.
#
# node-worker (8600):
#   NODE_MANAGEMENT_HOST=0.0.0.0
#   NODE_MANAGEMENT_PORT=8600
#   NODE_MANAGEMENT_URL=http://node-worker:8600
#   NODE_WORKER_PORT=8600
#   NODE_WORKER_HOST=0.0.0.0
#
# node-registry (8610):
#   NODE_MANAGEMENT_HOST=0.0.0.0
#   NODE_MANAGEMENT_PORT=8610
#   NODE_MANAGEMENT_URL=http://node-registry:8610
#   NODE_REGISTRY_PORT=8610
#   NODE_REGISTRY_HOST=0.0.0.0
#
# node-gov (8620):
#   NODE_MANAGEMENT_HOST=0.0.0.0
#   NODE_MANAGEMENT_PORT=8620
#   NODE_MANAGEMENT_URL=http://node-gov:8620
#   NODE_GOV_PORT=8620
#   NODE_GOV_HOST=0.0.0.0
#
# node-utils (8630):
#   NODE_MANAGEMENT_HOST=0.0.0.0
#   NODE_MANAGEMENT_PORT=8630
#   NODE_MANAGEMENT_URL=http://node-utils:8630
#   NODE_UTILS_PORT=8630
#   NODE_UTILS_HOST=0.0.0.0
# =============================================================================
