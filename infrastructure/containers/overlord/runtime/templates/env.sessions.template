# =============================================================================
# Lucid sessions plane — baseline template for .env.sessions
# Path: infrastructure/containers/overlord/runtime/templates/env.sessions.template
#
# Usage:
#   Copy to configs/environment/.env.sessions (or sessions/core as per your layout)
#   and merge with .env.foundation, .env.core, .env.secrets.
#
# Reference:
#   infrastructure/containers/sessions/docker-compose.session-images.yml
# =============================================================================

# =============================================================================
# OVERLORD / DISCOVERY
# =============================================================================
LUCID_SESSION_OVERLORD=1
SESSION_OVERLORD_PORT=8110

# =============================================================================
# SHARED RUNTIME (typical for all session stack services)
# =============================================================================
LUCID_ENV=production
LUCID_PLATFORM=arm64
LOG_LEVEL=INFO
DEBUG=false
PYTHONPATH=/app
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# =============================================================================
# INTEGRATION — set from foundation/core (passwords from .env.secrets)
# =============================================================================
API_GATEWAY_URL=http://api-gateway:8080
AUTH_SERVICE_URL=http://auth-service:8081
MONGODB_URL=mongodb://lucid:${MONGODB_PASSWORD}@lucid-mongodb:27017/lucid?authSource=admin
REDIS_URL=redis://:${REDIS_PASSWORD}@lucid-redis:6379/0

# =============================================================================
# SESSION RECORDER — hardware paths (session-recorder service only)
# =============================================================================
LUCID_RECORDING_PATH=/data/recordings
LUCID_CHUNK_OUTPUT_PATH=/data/chunks
LUCID_HARDWARE_ACCELERATION=true
LUCID_VIDEO_CODEC=h264_v4l2m2m
LUCID_AUDIO_CODEC=opus
LUCID_BITRATE=2000k
LUCID_FPS=30

# =============================================================================
# PER-SERVICE SERVICE_NAME / PORT / HOST
# Duplicate keys are invalid in one .env; set per service in compose or split files.
#
# session-pipeline:        SERVICE_NAME=session-pipeline        PORT=8083  HOST=session-pipeline
# session-recorder:        SERVICE_NAME=session-recorder        PORT=8090  HOST=session-recorder
# session-chunk-processor: SERVICE_NAME=session-chunk-processor   PORT=8010  HOST=session-chunk-processor
# session-storage:         SERVICE_NAME=session-storage         PORT=8020  HOST=session-storage
# session-api:             SERVICE_NAME=session-api             PORT=8113  HOST=session-api
# session-anchoring:       SERVICE_NAME=session-anchoring       PORT=8084  HOST=session-anchoring
# session-pipeline-manager:SERVICE_NAME=session-pipeline-manager PORT=7990  HOST=session-pipeline-manager
# session-management:      SERVICE_NAME=session-management      PORT=9090  HOST=session-management
# session-systems-control: SERVICE_NAME=session-systems-control   PORT=7988  HOST=session-systems-control
# =============================================================================
