# =============================================================================
# Lucid database plane — baseline template for .env.database
# Path: infrastructure/containers/overlord/runtime/templates/env.database.template
#
# Usage:
#   Copy to configs/environment/.env.database and merge with .env.foundation,
#   .env.core, and .env.secrets.
#
# References:
#   infrastructure/containers/database/Dockerfile.database (lucid-database tooling)
#   node/docker-compose.yml — Mongo/Redis images use foundation/core/secrets
# =============================================================================

# =============================================================================
# OVERLORD / DISCOVERY
# =============================================================================
LUCID_DATABASE_OVERLORD=1
DATABASE_OVERLORD_PORT=8120

# =============================================================================
# SHARED RUNTIME (database utilities / monitoring container)
# =============================================================================
LUCID_ENV=production
LUCID_PLATFORM=arm64
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# lucid-database distroless service (Dockerfile.database)
MONITORING_SERVICE_PORT=27018
PROMETHEUS_ENABLED=true

# =============================================================================
# MONGODB
# =============================================================================
MONGODB_HOST=lucid-mongodb
MONGODB_PORT=27017
LUCID_MAIN_DATABASE_NAME=lucid
MONGODB_URI=mongodb://lucid:${MONGODB_PASSWORD}@lucid-mongodb:27017/lucid?authSource=admin
MONGODB_URL=mongodb://lucid:${MONGODB_PASSWORD}@lucid-mongodb:27017/lucid?authSource=admin

# =============================================================================
# REDIS
# =============================================================================
LUCID_REDIS_HOST=lucid-redis
REDIS_HOST=lucid-redis
REDIS_PORT=6379
REDIS_URL=redis://:${REDIS_PASSWORD}@lucid-redis:6379/0

# =============================================================================
# ELASTICSEARCH (if used by database/elasticsearch jobs)
# =============================================================================
ELASTICSEARCH_HOST=lucid-elasticsearch
ELASTICSEARCH_PORT=9200

# =============================================================================
# API / GATEWAY (clients calling from database tooling)
# =============================================================================
LUCID_MAIN_GATEWAY=api-gateway
LUCID_MAIN_GATEWAY_PORT=8080

# =============================================================================
# TLS — paths inside distroless image layout when certs are mounted
# =============================================================================
SSL_CERT_PATH=/app/etc/ssl/certs/ca-certificates.crt
SSL_PRIVATE_KEY_PATH=/app/etc/private/ca-certificates.key
SSL_PUBLIC_KEY_PATH=/app/etc/public/ca-certificates.key

# =============================================================================
# OPTIONAL — per-job env files (see scripts/config / infrastructure/docker/databases/env)
# Duplicate keys: use separate files for backup vs migration vs monitoring.
#   .env.database-backup
#   .env.database-restore
#   .env.database-monitoring
#   .env.database-migration
# =============================================================================
