# syntax=docker/dockerfile:1.5
# LUCID ON-SYSTEM CHAIN CLIENT — Distroless Python (payment / anchoring plane)
# Path: infrastructure/containers/payment_systems/Dockerfile.on-system-chain-client
# Build context: repository root (.)
# host-config.yml: on_system_chain_client → on-system-chain-client:8040
# Compose: infrastructure/containers/payment_systems/docker-compose.payment-internal.yml

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=1.0.0
ARG TARGETPLATFORM=linux/arm64
ARG BUILDPLATFORM=linux/amd64
ARG PYTHON_VERSION=3.11

############################
# Stage 1 – Builder
############################
FROM --platform=$TARGETPLATFORM python:3.11-slim-bookworm AS builder

ARG BUILDPLATFORM
ARG TARGETPLATFORM
ARG PYTHON_VERSION

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_PREFER_BINARY=1 \
    DEBIAN_FRONTEND=noninteractive

WORKDIR /build

# LUCID_IMAGE_CONFIG: .env.secrets + .env.master (builder)
RUN mkdir -p /build/configs /build/host /build/app/chain_client /build/tmp
COPY configs/environment/.env.secrets /build/configs/.env.secrets
COPY master-env-config.txt /build/configs/.env.master

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    rm -rf /var/lib/apt/lists/* && \
    apt-get update --allow-releaseinfo-change && \
    apt-get install -y --no-install-recommends \
        build-essential gcc g++ libffi-dev libssl-dev pkg-config \
        curl ca-certificates tini \
        python3-wheel python3-dev python3-pip python3-setuptools \
    && apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

RUN printf "LUCID_ON_SYSTEM_CHAIN_CLIENT_RUNTIME" > /var/run/.keep && \
    printf "LUCID_ON_SYSTEM_CHAIN_CLIENT_LIB" > /var/lib/.keep && \
    chown -R 65532:65532 /var/run /var/lib && chmod 644 /var/run/.keep /var/lib/.keep

RUN mkdir -p /usr/local/lib/python3.11/site-packages /usr/local/bin && \
    chown -R 65532:65532 /usr/local/lib/python3.11/site-packages /usr/local/bin

RUN mkdir -p /app-dirs/cache/on-system-chain-client /app-dirs/data/on-system-chain-client /app-dirs/logs/on-system-chain-client && \
    printf "LUCID_ON_SYSTEM_CHAIN_CLIENT_CACHE_$(date +%s)" > /app-dirs/cache/on-system-chain-client/.keep && \
    printf "LUCID_ON_SYSTEM_CHAIN_CLIENT_DATA_$(date +%s)" > /app-dirs/data/on-system-chain-client/.keep && \
    printf "LUCID_ON_SYSTEM_CHAIN_CLIENT_LOGS_$(date +%s)" > /app-dirs/logs/on-system-chain-client/.keep && \
    chown -R 65532:65532 /app-dirs

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --upgrade pip setuptools wheel

COPY blockchain/on_system_chain/requirements.chain-client.txt ./requirements.txt

RUN --mount=type=cache,target=/root/.cache/pip \
    mkdir -p /build/wheels && \
    printf "LUCID_ON_SYSTEM_CHAIN_CLIENT_WHEELS_$(date +%s)" > /build/wheels/.keep && \
    pip wheel --no-cache-dir --wheel-dir /build/wheels -r ./requirements.txt

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir --no-index --find-links /build/wheels -r ./requirements.txt

RUN printf "LUCID_ON_SYSTEM_CHAIN_CLIENT_PACKAGES_$(date +%s)" > /usr/local/lib/python3.11/site-packages/.lucid-marker && \
    chown 65532:65532 /usr/local/lib/python3.11/site-packages/.lucid-marker

COPY blockchain/chain_client/ /build/app/chain_client/

COPY infrastructure/containers/host-config.yml ./host/host-config.yml
COPY infrastructure/containers/payment_systems/docker-compose.payment-internal.yml ./configs/docker-compose.payment-internal.yml
COPY infrastructure/containers/payment_systems/docker-compose.payment-externals.yml ./configs/docker-compose.payment-externals.yml
COPY infrastructure/containers/services/ ./configs/services/

RUN ON_SYSTEM_CHAIN_RPC_URL=http://127.0.0.1:8545 \
    python3.11 -m py_compile /build/app/chain_client/on_system_chain_client.py

############################
# Stage 2 – Runtime (Distroless)
############################
FROM --platform=$TARGETPLATFORM gcr.io/distroless/python3-debian12:latest

WORKDIR /app

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION=1.0.0

LABEL maintainer="Lucid Development Team" \
      org.opencontainers.image.title="Lucid On-System Chain Client" \
      org.opencontainers.image.description="EVM-compatible chain client for Lucid anchoring (on-system chain)" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.source="https://github.com/HamiGames/Lucid" \
      com.lucid.service="on-system-chain-client" \
      com.lucid.platform="arm64" \
      com.lucid.cluster="payment" \
      com.lucid.security="distroless" \
      com.lucid.expose="8040" \
      com.lucid.plane="support" \
      com.lucid.architecture="linux/arm64" \
      com.lucid.vulnerabilities="zero" \
      com.lucid.tor.compatible="true"

ENV PATH=/app/usr/local/bin:/app/usr/bin:/app/bin:$PATH \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app:/app/usr/local/lib/python3.11/site-packages \
    PYTHONIOENCODING=utf-8 \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    LUCID_HOST_CONFIG_PATH=/app/host/host-config.yml \
    LUCID_HOST_CONFIG_SERVICE_KEY=on_system_chain_client \
    LUCID_SERVICE_HOST_IP=172.20.10.39 \
    LUCID_SERVICE_HTTP_PATH=http://on-system-chain-client:8040/app \
    ON_SYSTEM_CHAIN_CLIENT_PORT=8040 \
    ON_SYSTEM_CHAIN_RPC_URL=http://lucid-on-system-chain:8545

# LUCID_IMAGE_CONFIG: .env.secrets + .env.master (runtime)
COPY --from=builder --chown=65532:65532 /build/configs/.env.secrets /app/configs/.env.secrets
COPY --from=builder --chown=65532:65532 /build/configs/.env.master /app/configs/.env.master

COPY --from=builder /var/run/ /app/var/run/
COPY --from=builder /var/lib/ /app/var/lib/
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /app/etc/ssl/certs/ca-certificates.crt
COPY --from=builder /usr/local/lib/python3.11/site-packages/ /app/usr/local/lib/python3.11/site-packages/
COPY --from=builder /usr/local/bin/ /app/usr/local/bin/
COPY --from=builder /usr/bin/ /app/usr/bin/
COPY --from=builder /usr/sbin/ /app/usr/sbin/

COPY --from=builder --chown=65532:65532 /build/wheels/ /app/wheels/
COPY --from=builder --chown=65532:65532 /app-dirs/cache /app/cache
COPY --from=builder --chown=65532:65532 /app-dirs/data /app/data
COPY --from=builder --chown=65532:65532 /app-dirs/logs /app/logs
COPY --from=builder --chown=65532:65532 /build/app/chain_client/ /app/chain_client/

COPY --from=builder --chown=65532:65532 /build/host/host-config.yml /app/host/host-config.yml
COPY --from=builder --chown=65532:65532 /build/configs/docker-compose.payment-internal.yml /app/configs/docker-compose.payment-internal.yml
COPY --from=builder --chown=65532:65532 /build/configs/docker-compose.payment-externals.yml /app/configs/docker-compose.payment-externals.yml
COPY --from=builder --chown=65532:65532 /build/configs/services/ /app/configs/services/

RUN ["/app/usr/bin/python3.11", "-c", "import os,sys; sp='/app/usr/local/lib/python3.11/site-packages'; sys.path.insert(0,sp); assert os.path.isdir(sp); m=os.path.join(sp,'.lucid-marker'); assert os.path.isfile(m) and os.path.getsize(m)>0; import aiohttp; print('on-system-chain-client packages OK')"]

EXPOSE 8040

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD ["/app/usr/bin/python3.11", "-c", "import os,socket,sys; p=int(os.getenv('ON_SYSTEM_CHAIN_CLIENT_PORT','8040')); s=socket.socket(); s.settimeout(2); r=s.connect_ex(('127.0.0.1',p)); s.close(); sys.exit(0 if r==0 else 1)"]

USER 65532:65532

ENTRYPOINT ["/app/usr/bin/tini", "--"]

CMD ["/app/usr/bin/python3.11", "/app/chain_client/on_system_chain_client.py"]
